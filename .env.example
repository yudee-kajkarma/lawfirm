# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. Get it from Atlas → Connect.
# For local dev, you can also use: mongodb://localhost:27017/crm
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/crm

# ─────────────────────────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace_me_with_a_random_string

# ─────────────────────────────────────────────────────────────────
# Encryption for settings integration secrets (SendGrid keys etc.)
# Generate with:  openssl rand -hex 16
# DO NOT change after deployment — would break decryption of stored secrets.
# ─────────────────────────────────────────────────────────────────
INTEGRATION_SECRET_KEY=replace_with_32_char_hex

# ─────────────────────────────────────────────────────────────────
# AWS S3 (Documents module)
# ─────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=crm-documents-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────
# Integration toggles
# Set to 'true' to call real APIs. Default 'false' uses stubs.
# ─────────────────────────────────────────────────────────────────
INTEGRATION_LIVE_SENDGRID=false
INTEGRATION_LIVE_TWILIO=false
INTEGRATION_LIVE_WHATSAPP=false

# ─────────────────────────────────────────────────────────────────
# Audit log retention (seconds). Default 180 days.
# ─────────────────────────────────────────────────────────────────
AUDIT_LOG_TTL_SECONDS=15552000

# ─────────────────────────────────────────────────────────────────
# Seed script — initial admin credentials
# Used by `npm run seed`. Change these and re-run for production.
# ─────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=System Admin
